{
  "name": "@prooflog/node",
  "version": "0.1.0",
  "description": "Cryptographically tamper-proof audit logging for Node.js",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
