  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  },
  "devDependencies": {
    "@prooflog/crypto": "workspace:*",
    "@prooflog/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
